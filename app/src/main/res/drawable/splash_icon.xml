<?xml version="1.0" encoding="utf-8"?>
<!-- Splash icon: padded so the logo fits fully within Android 12+ circular safe zone.
     The system clips this to a circle, so we add ~20% inset on all sides. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:drawable="@drawable/ic_launcher_premium"
        android:bottom="48dp"
        android:left="48dp"
        android:right="48dp"
        android:top="48dp" />
</layer-list>
